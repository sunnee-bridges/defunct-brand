---
interface Props {
  title?: string;
  text?: string;
  url?: string;
  showCopyButton?: boolean;
}

const {
  title = "Share this memory",
  text = "Remember Freshen Up? Share this with someone who used to chew it.",
  url,
  showCopyButton = true,
} = Astro.props;

const shareUrl = url ?? Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedText = encodeURIComponent(text);

const xHref = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedText}`;
const facebookHref = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const emailHref = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`${text}\n\n${shareUrl}`)}`;
---

<section class="share-prompt not-prose">
  <p>{text}</p>

  <div class="share-actions">
    <a href={xHref} target="_blank" rel="noopener noreferrer" aria-label="Share on X">
      <span aria-hidden="true">𝕏</span>
      <span>Share on X</span>
    </a>

    <a href={facebookHref} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
      <span aria-hidden="true">f</span>
      <span>Facebook</span>
    </a>

    <a href={emailHref} aria-label="Share by email">
      <span aria-hidden="true">✉</span>
      <span>Email</span>
    </a>

    {showCopyButton && (
      <button type="button" data-copy-url={shareUrl} aria-label="Copy link">
        <span aria-hidden="true">🔗</span>
        <span>Copy link</span>
      </button>
    )}
  </div>
</section>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const button = target.closest("[data-copy-url]");
    if (!(button instanceof HTMLButtonElement)) return;

    const url = button.dataset.copyUrl;
    if (!url) return;

    const originalText = button.textContent;

    try {
      await navigator.clipboard.writeText(url);
      button.textContent = "Copied!";
      setTimeout(() => {
        button.textContent = originalText;
      }, 2000);
    } catch {
      button.textContent = "Copy failed";
      setTimeout(() => {
        button.textContent = originalText;
      }, 2000);
    }
  });
</script>

<style>
  .share-prompt {
    margin: 2rem 0;
    padding: 1rem 0;
    border-top: 1px solid rgb(226 232 240);
    border-bottom: 1px solid rgb(226 232 240);
    font-size: 1.25rem;
  }

  :global(.dark) .share-prompt {
    border-color: rgb(51 65 85);
  }

  .share-prompt p {
    margin: 0 0 0.9rem;
    color: rgb(71 85 105);
    line-height: 1.6;
  }

  :global(.dark) .share-prompt p {
    color: rgb(148 163 184);
  }

  .share-actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    align-items: flex-start;
  }

  .share-actions a,
  .share-actions button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    appearance: none;
    border: 0;
    background: none;
    padding: 0;
    font: inherit;
    font-weight: 600;
    color: rgb(37 99 235);
    cursor: pointer;
    text-decoration: none;
  }

  .share-actions a:hover,
  .share-actions button:hover {
    text-decoration: underline;
  }

  :global(.dark) .share-actions a,
  :global(.dark) .share-actions button {
    color: rgb(96 165 250);
  }
</style>
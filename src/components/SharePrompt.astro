---
interface Props {
  title?: string;
  text?: string;
  url?: string;
  showCopyButton?: boolean;
}
const {
  title = "Share this memory",
  text = "Remember Freshen Up? Share this with someone who used to chew it.",
  url,
  showCopyButton = true,
} = Astro.props;
const shareUrl = url ?? Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedText = encodeURIComponent(text);
const xHref = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedText}`;
const facebookHref = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const redditHref = `https://reddit.com/submit?url=${encodedUrl}&title=${encodedText}`;
const emailHref = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`${text}\n\n${shareUrl}`)}`;
---

<section class="share-prompt not-prose">
  <p class="share-label">Share this page</p>
  <div class="share-actions">
    <a href={xHref} target="_blank" rel="noopener noreferrer" aria-label="Share on X" class="share-btn x-btn">
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.736-8.849L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      <span>X</span>
    </a>

    <a href={facebookHref} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" class="share-btn fb-btn">
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
      </svg>
      <span>Facebook</span>
    </a>

    <a href={redditHref} target="_blank" rel="noopener noreferrer" aria-label="Share on Reddit" class="share-btn reddit-btn">
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
      </svg>
      <span>Reddit</span>
    </a>

    <a href={emailHref} aria-label="Share by email" class="share-btn email-btn">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <span>Email</span>
    </a>

    {showCopyButton && (
      <button type="button" data-copy-url={shareUrl} aria-label="Copy link" class="share-btn copy-btn">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <span data-copy-label>Copy link</span>
      </button>
    )}
  </div>
</section>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-copy-url]");
    if (!(button instanceof HTMLButtonElement)) return;
    const url = button.dataset.copyUrl;
    if (!url) return;
    const label = button.querySelector("[data-copy-label]");
    const original = label?.textContent ?? "Copy link";
    try {
      await navigator.clipboard.writeText(url);
      if (label) label.textContent = "Copied!";
      setTimeout(() => { if (label) label.textContent = original; }, 2000);
    } catch {
      if (label) label.textContent = "Copy failed";
      setTimeout(() => { if (label) label.textContent = original; }, 2000);
    }
  });
</script>

<style>
  .share-prompt {
    margin: 2rem 0;
    padding: 1rem 0;
    border-top: 1px solid rgb(226 232 240);
    border-bottom: 1px solid rgb(226 232 240);
  }
  :global(.dark) .share-prompt {
    border-color: rgb(51 65 85);
  }
  .share-label {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(100 116 139);
  }
  :global(.dark) .share-label {
    color: rgb(148 163 184);
  }

  /* ✅ Key fix: row layout that wraps on mobile */
  .share-actions {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.85rem;
    border-radius: 9999px;
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }
  .share-btn:hover { opacity: 0.85; }

  .x-btn      { background: #000;     color: #fff; }
  .fb-btn     { background: #1877F2;  color: #fff; }
  .reddit-btn { background: #FF4500;  color: #fff; }
  .email-btn  { background: rgb(226 232 240); color: rgb(30 41 59); }
  .copy-btn   { background: rgb(226 232 240); color: rgb(30 41 59); }

  :global(.dark) .email-btn,
  :global(.dark) .copy-btn {
    background: rgb(51 65 85);
    color: rgb(226 232 240);
  }
</style>
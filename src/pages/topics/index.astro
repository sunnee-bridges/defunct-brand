---
import Base from "../../layouts/Base.astro";

/* ---------- Normalization helpers ---------- */
function normalizeTopicName(raw: unknown): string {
  let s = String(raw || "")
    .trim()
    .replace(/[’']/g, "'")
    .replace(/[-_]+/g, " ")
    .replace(/\s{2,}/g, " ");
  if (!s) return "";

  const mShort = s.match(/^'?([0-9]{2})s$/i);
  if (mShort) return `19${mShort[1]}0s`;
  if (/^(?:18|19|20)\d0s$/i.test(s)) return s;

  const lower = s.toLowerCase().replace(/\s+/g, " ");
  const map: Record<string, string> = {
    "e commerce": "E-commerce",
    "e-commerce": "E-commerce",
    "ecommerce": "E-commerce",
    "software internet": "Software & Internet",
    "software/internet": "Software & Internet",
    "pc clone era": "PC clone era",
    "p2p": "P2P",
    "mmo": "MMO",
    "qwerty": "QWERTY",
    "gm division": "GM division",
    "video game consoles": "Video game consoles",
    "instant messaging": "Instant messaging",
    "dot com": "Dot-com",
    "photography retail": "Photography retail",
    "civil rehabilitation": "Civil rehabilitation",
    "brand retired": "Brand retired",
    "brand sold": "Brand sold",
    "brand consolidation": "Brand consolidation",
  };
  if (map[lower]) return map[lower];

  return s.replace(/\b([a-z])(\w*)/g, (_, a, rest) => a.toUpperCase() + rest.toLowerCase());
}

function slugifyTopic(name: string): string {
  return String(name)
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

/* ---------- Page meta ---------- */
const PAGE_TITLE = "Browse Topics • Hubs";
const PAGE_DESC =
  "Explore topic hubs that group discontinued and defunct brands by shared themes, eras, industries, and events.";
const CANONICAL = Astro.site ? new URL("/topics/", Astro.site).href : "/topics/";

/* ---------- Load content ---------- */
const modules = import.meta.glob("/src/content/brands/*.json", {
  eager: true,
  import: "default",
}) as Record<string, any>;

/* ---------- Aggregate counts ---------- */
const counts = new Map<string, { label: string; count: number }>();
for (const mod of Object.values(modules)) {
  const b = (mod as any) || {};
  if (!Array.isArray(b.topics)) continue;

  for (const t of b.topics) {
    const label = normalizeTopicName(t);
    if (!label) continue;

    const slug = slugifyTopic(label);
    const prev = counts.get(slug);
    counts.set(slug, { label, count: (prev?.count || 0) + 1 });
  }
}

const topics = Array.from(counts.entries())
  .map(([slug, v]) => ({ slug, name: v.label, count: v.count }))
  .sort((a, b) => a.name.localeCompare(b.name));

const totalTopics = topics.length;
const totalBrandsGrouped = topics.reduce((sum, t) => sum + t.count, 0);
const featured = topics
  .slice()
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name))
  .slice(0, 8);

/* ---------- JSON-LD ---------- */
const collectionPageLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: PAGE_TITLE,
  description: PAGE_DESC,
  url: CANONICAL,
};

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Topics",
  itemListElement: topics.slice(0, 200).map((t, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: t.name,
    url: Astro.site
      ? new URL(`/topics/${encodeURIComponent(t.slug)}/`, Astro.site).href
      : `/topics/${encodeURIComponent(t.slug)}/`,
    numberOfItems: t.count,
  })),
};
---

<Base title={PAGE_TITLE} description={PAGE_DESC}>
  <Fragment slot="head">
    <link rel="canonical" href={CANONICAL} />
    <meta name="description" content={PAGE_DESC} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={CANONICAL} />
    <meta property="og:title" content={PAGE_TITLE} />
    <meta property="og:description" content={PAGE_DESC} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={PAGE_TITLE} />
    <meta name="twitter:description" content={PAGE_DESC} />

    <script type="application/ld+json" set:html={JSON.stringify(collectionPageLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />

    <style is:inline>
      .topic-card {
        position: relative;
        display: block;
        height: 100%;
        border-radius: 0.75rem;
        border: 1px solid rgb(226 232 240);
        background: white;
        padding: 1rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      }

      .dark .topic-card {
        background: rgb(15 23 42);
        border-color: rgb(51 65 85);
      }

      .topic-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        border-color: rgb(59 130 246);
      }

      .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.25rem;
        padding: 0.2rem 0.55rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 600;
        background: rgb(239 246 255);
        color: rgb(30 64 175);
      }

      .dark .count-badge {
        background: rgba(59, 130, 246, 0.15);
        color: rgb(147 197 253);
      }

      .section-card {
        border: 1px solid rgb(226 232 240);
        border-radius: 0.75rem;
        padding: 1rem;
        background: rgb(248 250 252);
      }

      .dark .section-card {
        border-color: rgb(51 65 85);
        background: rgb(15 23 42 / 0.65);
      }

      .stat-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        padding: 0.25rem 0.65rem;
        font-size: 0.875rem;
        background: rgb(239 246 255);
        color: rgb(30 64 175);
      }

      .dark .stat-chip {
        background: rgba(59, 130, 246, 0.15);
        color: rgb(147 197 253);
      }
    </style>
  </Fragment>

  <nav class="mb-4 flex flex-wrap gap-2" aria-label="Breadcrumb">
    <a href="/" class="chip focus-ring">← Home</a>
    <a href="/az/" class="chip focus-ring">A–Z</a>
    <span class="chip opacity-70 cursor-default" aria-current="page">Topics</span>
  </nav>

  <h1 id="top" class="text-2xl md:text-3xl font-bold mb-2">Browse Topics</h1>

  <div class="prose prose-sm dark:prose-invert max-w-none mb-6">
    <p>
      Explore topic hubs that connect vanished brands through shared themes like nostalgia,
      bankruptcies, discontinued products, industries, and eras.
    </p>
  </div>

  <div class="mb-6 flex flex-wrap gap-3 text-sm">
    <span class="stat-chip">Total topics: {totalTopics}</span>
    <span class="stat-chip">Total brand-topic links: {totalBrandsGrouped}</span>
  </div>

  {featured.length > 0 && (
    <section class="section-card mb-8" aria-labelledby="featured-topics">
      <h2 id="featured-topics" class="text-xl font-semibold mb-3 text-slate-900 dark:text-slate-100">
        Popular topics
      </h2>
      <div class="flex flex-wrap gap-2">
        {featured.map((t) => (
          <a href={`/topics/${t.slug}/`} class="chip focus-ring">
            {t.name}
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="mb-8 max-w-2xl">
    <label for="q" class="block text-sm text-slate-700 dark:text-slate-300 mb-2">
      Search topics:
    </label>
    <input
      id="q"
      type="search"
      placeholder="e.g., Bankruptcy, Video games, 1990s"
      class="w-full rounded-md border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-1.5 text-sm text-slate-900 dark:text-slate-100"
    />
  </div>

  <section class="mb-8" aria-labelledby="browse-topics">
    <div class="flex items-center justify-between gap-4 mb-4 flex-wrap">
      <h2 id="browse-topics" class="text-xl font-semibold text-slate-900 dark:text-slate-100">
        Browse all topics
      </h2>
    </div>

    {topics.length === 0 ? (
      <p class="text-slate-600 dark:text-slate-400">No topics available yet.</p>
    ) : (
      <ul id="topics-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topics.map((t) => (
          <li data-topic-item data-topic-name={t.name.toLowerCase()}>
            <a
              href={`/topics/${t.slug}/`}
              class="topic-card focus-ring"
              aria-label={`${t.name} (${t.count} brands). Explore vanished brands connected to ${t.name}.`}
            >
              <div class="flex items-start justify-between gap-3 mb-2">
                <span class="text-lg font-semibold text-slate-900 dark:text-slate-100">
                  {t.name}
                </span>
                <span class="count-badge">{t.count}</span>
              </div>

              <p class="text-sm text-slate-600 dark:text-slate-300 mb-3">
                Explore vanished brands connected to {t.name}.
              </p>

              <span class="text-sm font-medium text-blue-600 dark:text-blue-400">
                Explore {t.name} →
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="mt-10" aria-labelledby="why-browse-topics">
    <h2 id="why-browse-topics" class="text-xl font-semibold mb-4 text-slate-900 dark:text-slate-100">
      Why browse by topic?
    </h2>
    <div class="prose prose-sm dark:prose-invert max-w-none">
      <p>
        Topics help readers find connections between brands that would not normally sit together
        in the same category. A topic like bankruptcy can cut across retail, airlines, and tech,
        while a topic like 1990s nostalgia may connect snacks, toys, and media brands.
      </p>
    </div>
  </section>

  <div class="mt-8">
    <a href="#top" class="chip focus-ring">↑ Back to top</a>
  </div>

  <script>
    const q = document.getElementById("q");
    const items = Array.from(document.querySelectorAll("[data-topic-item]"));

    function applyTopicFilter() {
      if (!q) return;

      const term = q.value.trim().toLowerCase();

      items.forEach((item) => {
        const label = item.getAttribute("data-topic-name") || "";
        const hit = !term || label.includes(term);
        item.hidden = !hit;
      });
    }

    if (q) {
      q.addEventListener("input", applyTopicFilter);
      applyTopicFilter();
    }
  </script>
</Base>
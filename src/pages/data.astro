---
// src/pages/data.astro
import Base from "../layouts/Base.astro";

// Free sample
const sampleCsvHref = "/data/brands-sample.csv";

// Schema rows
const schema: Array<[string, string, string]> = [
  ["brand","string","Brand name"],
  ["slug","string","URL-safe unique key"],
  ["category","string","Primary category (e.g., Consumer electronics)"],
  ["country","string|null","Primary country/market (if known)"],
  ["active_start","int|null","Year founded/started"],
  ["active_end","int|null","Year ended (if known)"],
  ["fate","string|null","Outcome (e.g., Bankrupt, Acquired)"],
  ["summary","string|null","One–two sentence summary"],
  ["wikipedia_url","string|null","Wikipedia article URL (where available)"],
];

// --- SEO helpers ---
const pageTitle = "Defunct Brands Dataset • CSV Downloads";
const pageDesc  = "Download the Defunct Brands dataset as CSV. Clean, structured data of discontinued brands with category, active years, and fate.";
const path      = "/data/";
const canonical = Astro.site ? new URL(path, Astro.site).href : path;

// Dataset JSON-LD (pure JSON; emitted via <script type="application/ld+json">)
const datasetLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Defunct Brands Dataset (CSV)",
  "description": "Structured dataset of discontinued/defunct brands with category, country, active years, fate, and summary. Free sample available; full dataset free for personal and research use.",
  "url": canonical,
  "creator": {
    "@type": "Organization",
    "name": "Vanished Brands",
    "url": "https://vanishedbrands.com/"
  },
  "license": "https://vanishedbrands.com/terms/",
  "isAccessibleForFree": true,
  "distribution": [
    {
      "@type": "DataDownload",
      "name": "Sample CSV",
      "encodingFormat": "text/csv",
      "contentUrl": `https://vanishedbrands.com${sampleCsvHref}`
    },
    {
      "@type": "DataDownload",
      "name": "Full CSV (request access)",
      "encodingFormat": "text/csv",
      "contentUrl": "https://vanishedbrands.com/contact/"
    }
  ]
};
const datasetLdJson = JSON.stringify(datasetLd);
---

<Base title={pageTitle} description={pageDesc} canonical={canonical}>
  <!-- Put SEO (canonical/OG/Twitter) + Dataset JSON-LD into the head -->
  <Fragment slot="head">
   
    <!-- Dataset JSON-LD -->
    <script type="application/ld+json" set:html={datasetLdJson} />
  </Fragment>

  <nav class="mb-4 flex flex-wrap gap-2">
    <a href="/" class="chip focus-ring">← Home</a>
    <a href="/az/" class="chip focus-ring">A–Z</a>
    <a href="/decade/" class="chip focus-ring">Decades</a>
  </nav>

  <h1 class="text-2xl md:text-3xl font-bold mb-2">Defunct Brands Dataset</h1>
  <p class="text-slate-700 dark:text-slate-300 mb-4">
    A cleaned CSV of brands, categories, active years, and fate.
  </p>

  <div class="grid gap-4 md:grid-cols-2 md:gap-4 lg:gap-6">
    <!-- Free sample -->
    <section class="rounded-xl border p-4 bg-white/80 dark:bg-slate-900/80 border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold mb-2">Free sample (10 brands)</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">
        A tiny slice for evaluation and non-commercial use.
      </p>
      <a
        class="btn-primary focus-ring"
        href={sampleCsvHref}
        download
        aria-label="Download sample CSV (10 brands)"
        title="Download sample CSV (10 brands)"
      >
        Download sample CSV
      </a>
    </section>

    <!-- Full dataset -->
    <section class="rounded-xl border p-4 bg-white/80 dark:bg-slate-900/80 border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold mb-2">Full dataset (CSV)</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">
        Free for personal and research use. Enter your email and we’ll send a download link.
      </p>
      <form id="csv-request-form" novalidate>
        <div class="flex flex-col sm:flex-row gap-2">
          <input
            id="csv-email"
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
            class="flex-1 rounded-md border border-slate-300 dark:border-slate-600
                   bg-white dark:bg-slate-800 px-3 py-2 text-sm
                   text-slate-900 dark:text-slate-100
                   focus:outline-none focus:ring-2 focus:ring-indigo-500"
          />
          <button
            type="submit"
            id="csv-submit"
            class="btn-primary focus-ring shrink-0"
          >
            Send download link
          </button>
        </div>
        <p id="csv-msg" class="mt-2 text-sm" aria-live="polite"></p>
      </form>
      <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">
        For commercial use, <a href="/contact/" class="underline">contact us</a> to arrange a license.
      </p>
    </section>
  </div>

  <!-- Schema -->
  <h2 class="text-lg font-semibold mt-8 lg:mt-10 mb-2">Schema</h2>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 dark:border-slate-700">
          <th class="text-left py-1 pr-3">Column</th>
          <th class="text-left py-1 pr-3">Type</th>
          <th class="text-left py-1">Description</th>
        </tr>
      </thead>
      <tbody>
        {schema.map(([name, type, desc]) => (
          <tr class="border-b border-slate-100 dark:border-slate-800">
            <td class="py-1 pr-3 font-medium">{name}</td>
            <td class="py-1 pr-3 text-slate-600 dark:text-slate-400">{type}</td>
            <td class="py-1">{desc}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- FAQ -->
  <section class="mt-6 space-y-2 text-sm text-slate-700 dark:text-slate-300">
    <details>
      <summary class="cursor-pointer font-medium">What's the file format?</summary>
      <div class="mt-1">UTF-8 CSV with a header row. New columns (if any) are appended to preserve backward compatibility.</div>
    </details>
    <details>
      <summary class="cursor-pointer font-medium">How often do you update?</summary>
      <div class="mt-1">Ad-hoc as new brands are added. Buyers can opt into annual updates.</div>
    </details>
    <details>
      <summary class="cursor-pointer font-medium">Commercial usage?</summary>
      <div class="mt-1">Personal and research use is free — email us to request. Commercial use (apps, products, redistribution) requires a license; <a href="/contact/" class="underline">contact us</a> to arrange.</div>
    </details>
  </section>

  <p class="mt-3 text-sm text-slate-700 dark:text-slate-300 max-w-2xl">
    Spotted a mistake in the dataset or have additional sources to suggest?
    <a
  href="/contact/"
  class="underline decoration-indigo-500 decoration-2 underline-offset-2 hover:decoration-indigo-600
         -mx-1 px-1 rounded-sm font-medium
         text-indigo-700 hover:text-indigo-900
         dark:text-indigo-300 dark:hover:text-indigo-200
         hover:bg-indigo-50 dark:hover:bg-slate-800"
>
  Get in touch via the contact form
</a>

    and I’ll review it for a future update.
  </p>

  <p class="mt-6 text-xs text-slate-600 dark:text-slate-400">
    <strong>License:</strong> Free sample under CC BY-NC 4.0. Full CSV free for personal/research use; commercial license available on request.
  </p>

  <script is:inline>
    (function () {
      const form   = document.getElementById('csv-request-form');
      const input  = document.getElementById('csv-email');
      const btn    = document.getElementById('csv-submit');
      const msg    = document.getElementById('csv-msg');
      if (!form) return;

      function setMsg(text, ok) {
        msg.textContent = text;
        msg.className = 'mt-2 text-sm ' + (ok
          ? 'text-green-700 dark:text-green-400'
          : 'text-red-600 dark:text-red-400');
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        const email = input.value.trim();
        if (!email) return;

        btn.disabled = true;
        btn.textContent = 'Sending…';
        msg.textContent = '';
        msg.className = 'mt-2 text-sm';

        try {
          const res  = await fetch('/.netlify/functions/request-csv', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
          });
          const data = await res.json().catch(() => ({}));

          if (res.ok && data.ok) {
            setMsg('Check your inbox — we sent a download link to ' + email + '.', true);
            form.reset();
          } else {
            setMsg(data.error || 'Something went wrong. Please try again.', false);
          }
        } catch {
          setMsg('Network error. Please try again.', false);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send download link';
        }
      });
    })();
  </script>
</Base>

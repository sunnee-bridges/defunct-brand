---
// src/pages/decade/index.astro
import Base from "../../layouts/Base.astro";
import { slugify } from "../../lib/slug.js";

/* ---- Load curated brand JSON at build time & de-dupe by slug ---- */
const modules = import.meta.glob("/src/content/brands/*.json", {
  eager: true,
  import: "default",
}) as Record<string, any>;

const bySlug = new Map<string, any>();
for (const raw of Object.values(modules)) {
  const b = raw as any;
  if (!b) continue;
  const key =
    String(b.slug || "").trim().toLowerCase() ||
    slugify(String(b.brand || ""));
  if (!key) continue;
  if (typeof b.category === "string") b.category = b.category.trim();
  if (!bySlug.has(key)) bySlug.set(key, b); // first-wins
}
const brands: any[] = Array.from(bySlug.values());

/* ---- Helpers ---- */
const toYear = (v: unknown): number | undefined => {
  if (v == null) return undefined;
  const m = String(v).match(/\d{3,4}/);
  if (!m) return undefined;
  const n = parseInt(m[0], 10);
  return Number.isFinite(n) ? n : undefined;
};
const decadeStart = (y: number) => Math.floor(y / 10) * 10;
const labelOf = (start: number) => `${start}s`;

/* ---- Build: decade label -> count (prefer end year, fallback start) ---- */
const counts = new Map<string, number>();
for (const b of brands) {
  const y = toYear(b?.active?.end) ?? toYear(b?.active?.start);
  if (y == null) continue;
  const label = labelOf(decadeStart(y));
  counts.set(label, (counts.get(label) ?? 0) + 1);
}

/* ---- Sorted available decades (e.g., "1990s", "2000s") ---- */
const decades = [...counts.keys()].sort((a, b) => parseInt(a) - parseInt(b));

/* ---- Optional editorial copy per decade ---- */
const decadeDescriptions: Record<string, string> = {
  "1950s": "Early postwar consumer brands, department stores, and regional names that later disappeared.",
  "1960s": "Legacy consumer products and retail brands tied to mid-century shopping culture.",
  "1970s": "Brands shaped by inflation, energy shocks, and shifting consumer habits.",
  "1980s": "Department stores, regional chains, and household brands remembered from peak mall culture.",
  "1990s": "Mall brands, media names, and early internet-era casualties that faded by the end of the decade.",
  "2000s": "Dot-com fallout, retail shakeouts, and discontinued products from a fast-changing consumer era.",
  "2010s": "Streaming disruption, e-commerce pressure, and major retail bankruptcies reshaped familiar brands.",
  "2020s": "Recent closures, discontinued products, and post-pandemic brand exits still fresh in public memory.",
};

const totalBrands = Array.from(counts.values()).reduce((sum, n) => sum + n, 0);

/* ---- SEO ---- */
const PAGE_TITLE = "Defunct Brands by Decade | Browse Vanished Brands Over Time";
const PAGE_DESC = decades.length
  ? `Explore defunct and discontinued brands by decade, from ${decades[0]} to ${decades[decades.length - 1]}, including retail, tech, food, and nostalgia brands.`
  : "Explore defunct and discontinued brands by decade.";
const CANONICAL = Astro.site ? new URL("/decade/", Astro.site).href : "/decade/";

/* ---- JSON-LD ---- */
const collectionPageLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: PAGE_TITLE,
  description: PAGE_DESC,
  url: CANONICAL,
};

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Defunct brands by decade",
  itemListElement: decades.map((d, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: d,
    url: Astro.site ? new URL(`/decade/${d}/`, Astro.site).href : `/decade/${d}/`,
    numberOfItems: counts.get(d) ?? 0,
  })),
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How are brands grouped by decade?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Brands are grouped by the decade in which they went defunct, based primarily on the end year in the dataset. If an end year is missing, the start year is used as a fallback so the brand can still appear in the archive.",
      },
    },
    {
      "@type": "Question",
      name: "What kinds of brands are included?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The decade pages include retail chains, food and drink products, consumer brands, technology products, media names, and other disappeared brands from different industries.",
      },
    },
  ],
};
---
<Base title={PAGE_TITLE} description={PAGE_DESC} canonical={CANONICAL} jsonLd={[collectionPageLd, itemListLd, faqLd]}>
  <Fragment slot="head">
   

    <meta property="og:type" content="website" />

    <script type="application/ld+json" set:html={JSON.stringify(collectionPageLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

    <style is:inline>
      .decade-card {
        position: relative;
        display: block;
        height: 100%;
        border-radius: 0.75rem;
        border: 1px solid rgb(226 232 240);
        background: white;
        padding: 1rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      }
      .dark .decade-card {
        background: rgb(15 23 42);
        border-color: rgb(51 65 85);
      }
      .decade-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        border-color: rgb(59 130 246);
      }
      .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.25rem;
        padding: 0.2rem 0.55rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 600;
        background: rgb(239 246 255);
        color: rgb(30 64 175);
      }
      .dark .count-badge {
        background: rgba(59, 130, 246, 0.15);
        color: rgb(147 197 253);
      }
      .section-card {
        border: 1px solid rgb(226 232 240);
        border-radius: 0.75rem;
        padding: 1rem;
        background: rgb(248 250 252);
      }
      .dark .section-card {
        border-color: rgb(51 65 85);
        background: rgb(15 23 42 / 0.65);
      }
    </style>
  </Fragment>

  <h1 id="top" class="text-2xl md:text-3xl font-bold mb-2">Defunct Brands by Decade</h1>

  <p class="text-slate-600 dark:text-slate-300 mb-5">
    {totalBrands} discontinued brands grouped by the era they disappeared — retail, tech, food, and more.
  </p>

  <div class="mb-8 flex flex-wrap items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
    <span class="chip opacity-90">Total decades: {decades.length}</span>
    <span class="chip opacity-90">Total brands grouped: {totalBrands}</span>
    {decades.length > 0 && (
      <span class="chip opacity-90">
        Coverage: {decades[0]}–{decades[decades.length - 1]}
      </span>
    )}
  </div>

  {decades.length === 0 ? (
    <p class="text-slate-600 dark:text-slate-400">No decades available yet.</p>
  ) : (
    <>
      <section aria-labelledby="browse-decades">
        <h2 id="browse-decades" class="text-xl font-semibold mb-4 text-slate-900 dark:text-slate-100">
          Browse decade archives
        </h2>

        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {decades.map((d) => {
            const n = counts.get(d) ?? 0;
            return (
              <li>
                <a
                  href={`/decade/${d}/`}
                  class="decade-card focus-ring"
                  title={`${n} ${n === 1 ? "brand" : "brands"} in the ${d}`}
                  aria-label={`${d} (${n} ${n === 1 ? "brand" : "brands"})`}
                >
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <span class="text-lg font-semibold text-slate-900 dark:text-slate-100">{d}</span>
                    <span class="count-badge">{n}</span>
                  </div>

                  <p class="text-sm text-slate-600 dark:text-slate-300 mb-3">
                    {decadeDescriptions[d] || `Browse vanished brands from the ${d}.`}
                  </p>

                  <span class="text-sm font-medium text-blue-600 dark:text-blue-400">
                    Explore {d} →
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>

      <section class="mt-10 space-y-3" aria-labelledby="faq">
        <h2 id="faq" class="text-base font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
          FAQ
        </h2>
        <div class="section-card">
          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-1">How are brands grouped?</h3>
          <p class="text-sm text-slate-600 dark:text-slate-300">By the decade they went defunct, using the end year as the primary signal. Start year is used as a fallback if no end year is available.</p>
        </div>
        <div class="section-card">
          <h3 class="font-semibold text-slate-900 dark:text-slate-100 mb-1">What's included?</h3>
          <p class="text-sm text-slate-600 dark:text-slate-300">Retail chains, food and drink brands, consumer electronics, media names, and other discontinued or defunct brands across industries.</p>
        </div>
      </section>
    </>
  )}

  <div class="mt-8">
    <a href="#top" class="chip focus-ring">↑ Back to top</a>
  </div>
</Base>